# ============================================
# TECXMATE - Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values
# Never commit .env.local to version control

# ============================================
# REQUIRED - Site Configuration
# ============================================

# Your site's public URL (used for SEO, sitemap, robots.txt, OpenGraph, etc.)
# Examples:
#   - Production: https://www.tecxmate.com
#   - Development: http://localhost:3000
#   - Preview: https://tecxmate-git-main.vercel.app
NEXT_PUBLIC_SITE_URL=https://tecxmate.com
ADMIN_PASSWORD=

# Vercel Blob token (required for Tecxbook upload/edit/delete)
BLOB_READ_WRITE_TOKEN=

# Google Tag Manager Container ID (format: GTM-XXXXXXX)
NEXT_PUBLIC_GTM_ID=

# Google Analytics 4 Measurement ID (format: G-XXXXXXX)
NEXT_PUBLIC_GA_ID=

# ============================================
# OPTIONAL - Firebase Configuration
# ============================================

# Firebase Web App Configuration
# Get these values from Firebase Console: https://console.firebase.google.com
# Project Settings > Your apps > Web app config
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ============================================
# REQUIRED - WordPress Blog Configuration
# ============================================

# WordPress Site URL
# For WordPress.com sites: use your site URL (e.g., 'yoursite.wordpress.com')
# For self-hosted WordPress: use your full domain (e.g., 'blog.yoursite.com')
# Example: phucphanblog.wordpress.com
WORDPRESS_SITE_URL=tecxmate.wordpress.com

# Optional: WordPress API Cache Revalidation Time (in seconds)
# Default: 300 (5 minutes)
# Set to 0 to disable caching
# WORDPRESS_REVALIDATE_TIME=300

# Optional: Number of posts per page
# Default: 9
# WORDPRESS_POSTS_PER_PAGE=9
# Contact form (Resend)
# Get your API key at https://resend.com
RESEND_API_KEY=
# Optional: custom from address (default: onboarding@resend.dev for testing)
# RESEND_FROM_EMAIL=contact@yourdomain.com
# Optional: where to receive form submissions (default: official@tecxmate.com)
# CONTACT_EMAIL=official@tecxmate.com

# ============================================
# OPTIONAL - AI Chatbot
# ============================================

# Vercel AI Gateway powers /api/chat. Keep this server-side only.
AI_GATEWAY_API_KEY=
# Gateway model id. Defaults to openai/gpt-5.1-mini.
CHATBOT_MODEL=openai/gpt-5.1-mini

# Upstash Redis enables rate limits, 90-day transcripts, and returning visitor memory.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Where chatbot escalation transcripts should be emailed.
CHATBOT_TRANSCRIPT_EMAIL=official@tecxmate.com

# Option A: push transcripts through the existing tecxbot /api/tecxmate-push bridge.
CHATBOT_LINE_PUSH_URL=
CHATBOT_LINE_PUSH_SECRET=
CHATBOT_LINE_TO=
CHATBOT_LINE_CHANNEL=tecxmate

# Option B: direct LINE push from this website if no bridge URL is configured.
CHATBOT_LINE_CHANNEL_ACCESS_TOKEN=

KV_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
REDIS_URL=
